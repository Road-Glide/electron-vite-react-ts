{
	"name": "create-electron-vite-react-ts",
	"version": "0.1.3",
	"description": "Create an Electron + Vite + React + TypeScript desktop app.",
	"license": "MIT",
	"type": "module",
	"bin": {
		"create-electron-vite-react-ts": "bin/create-electron-vite-react-ts.js"
	},
	"files": [
		"bin",
		"electron",
		"public",
		"src",
		".editorconfig",
		".env.example",
		"eslint.config.mjs",
		".gitignore",
		".prettierignore",
		".prettierrc",
		"electron.vite.config.ts",
		"tsconfig.app.json",
		"tsconfig.electron.json",
		"tsconfig.json",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"create:test": "node ./bin/create-electron-vite-react-ts.js ./tmp-create-test",
		"dev": "electron-vite dev",
		"build": "tsc -b && electron-vite build",
		"lint": "eslint .",
		"start": "electron-vite preview",
		"release": "npm run build && electron-builder",
		"format": "prettier --write .",
		"clean": "rimraf dist release node_modules/.cache",
		"lang": "node -e \"if(process.platform==='win32'){require('child_process').spawnSync('chcp',['65001'],{stdio:'inherit',shell:true})}\""
	},
	"dependencies": {
		"electron-vite": "^5.0.0",
		"prettier": "^3.8.3",
		"react": "^18.2.0",
		"react-dom": "^18.2.0"
	},
	"devDependencies": {
		"@types/react": "^18.2.64",
		"@types/react-dom": "^18.2.21",
		"@typescript-eslint/eslint-plugin": "^8.58.2",
		"@typescript-eslint/parser": "^8.58.2",
		"@vitejs/plugin-react": "^4.2.1",
		"electron": "^39.8.5",
		"electron-builder": "^26.8.1",
		"eslint": "^9.39.4",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-react-refresh": "^0.5.2",
		"typescript": "^5.2.2",
		"vite": "^6.4.2",
		"vite-plugin-electron": "^0.29.1",
		"vite-plugin-electron-renderer": "^0.14.5"
	},
	"build": {
		"directories": {
			"output": "release"
		}
	},
	"main": "dist/main/main.js"
}
